<UserControl x:Class="ComicShelfUI.UserControls.VolumeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:domain="clr-namespace:Domain;assembly=Domain" 
             xmlns:local="clr-namespace:ComicShelfUI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent" d:DataContext="{x:Type domain:Volume}" Loaded="CardLoaded" MouseDoubleClick="ClickedTwice">
    <Grid VerticalAlignment="Center" Margin="5 2" x:Name="BackgroundGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <CheckBox  Grid.Column="0" IsChecked="{Binding IsOwned}" Margin="5 0 5 0" x:Name="IsOwnCheckBox"     FontSize="20" VerticalAlignment="Center" Checked="CheckClicked" Unchecked="CheckClicked"/>
        <TextBlock Grid.Column="1" Text="{Binding Name}"         Margin="5 0 0 0" Foreground="White"       FontSize="20" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="-" x:Name="Sep"         Margin="2 0 2 0" Foreground="White"       FontSize="20" VerticalAlignment="Center" Visibility="Hidden"/>
        <TextBlock Grid.Column="3" Text="{Binding Details}"      Margin="5 0 0 0" Foreground="#AFFFFFFF"   FontSize="18" VerticalAlignment="Center" d:Text="Some details"/>
        <!--
            <TextBlock Grid.Column="2" Text="Data de publicação (pra trackear qual comprar)"     Margin="5 0 0 0" Foreground="White" FontSize="20" VerticalAlignment="Center" Visibility="Hidden" d:Visibility="Visible"/>
        -->
    </Grid>
</UserControl>
