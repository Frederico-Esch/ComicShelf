<Window x:Class="ComicShelfUI.Windows.AddVolume"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:ComicShelfUI.Windows"
        xmlns:domain="clr-namespace:Domain;assembly=Domain"
        mc:Ignorable="d"
        Title="New Volume" MaxHeight="300" MinHeight="300" Height="300" Width="500" Icon="/Resources/icon.png"
        Background="{StaticResource BackgroundColor}"
        Loaded="WindowLoaded" Closing="ClosingEvent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#BB86FC"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#3700B3"/>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <ControlTemplate x:Key="ButtonTemplate" TargetType="Button">
            <Border
                CornerRadius="5"
                Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}"
                Margin="{TemplateBinding Margin}"
                Cursor="Hand">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </ControlTemplate>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Template" Value="{StaticResource ButtonTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AcceptButton" BasedOn="{StaticResource ButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="PaleGreen"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Lime"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="PaleGreen"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RejectButton" BasedOn="{StaticResource ButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="PaleVioletRed"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Red"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="PaleVioletRed"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <domain:Volume/>
    </Window.DataContext>

    <StackPanel Margin="5">
        <RadioButton x:Name="chkNumber" GroupName="NameType" IsChecked="True" Foreground="White">
            Number
        </RadioButton>
        <TextBox x:Name="VolumeNumber" Margin="0 2 0 5" FontSize="20"
                 IsEnabled="{Binding ElementName=chkNumber, Path=IsChecked}" Text="" KeyDown="NextElement"
                 TextChanged="ValidateText" PreviewTextInput="ValidateText" DataObject.Pasting="ValidateText"
         />

        <RadioButton x:Name="chkName" GroupName="NameType" IsChecked="False" Foreground="White">
            Special Edition
        </RadioButton>
        <TextBox x:Name="VolumeSpecialName" Margin="0 2 0 5" FontSize="20" VerticalAlignment="Center"
                 IsEnabled="{Binding ElementName=chkName, Path=IsChecked}" Text="" KeyDown="NextElement"
        />

        <Label>Details</Label>
        <TextBox x:Name="VolumeDetails" Margin="0 2 0 5" FontSize="20" VerticalAlignment="Center" Text="{Binding Details}" KeyDown="NextElement"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="5" Style="{StaticResource RejectButton}" Click="Delete" Visibility="Hidden" x:Name="DeleteButton" d:Visibility="Visible">
                <icons:Material Kind="TrashCan"/>
            </Button>
            <Button Margin="5" Style="{StaticResource AcceptButton}" Click="Save">
                <icons:Material Kind="ContentSave"/>
            </Button>
            <Button Margin="5" Style="{StaticResource RejectButton}" Click="Cancel">
                <icons:Material Kind="Cancel"/>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
