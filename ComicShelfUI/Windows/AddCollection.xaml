<Window x:Class="ComicShelfUI.Windows.AddCollection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ComicShelfUI.Windows"
        xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="AddCollection" Height="450" Width="800" 
        Background="{StaticResource BackgroundColor}">
    <Window.Resources >
        <BitmapImage x:Key="GenericCover" UriSource="/Resources/GenericComicBookCover.jpg" />
        <ControlTemplate x:Key="CircularButton" TargetType="Button">
            <Border
                CornerRadius="50"
                Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}"
                Margin="{TemplateBinding Margin}"
                Cursor="Hand">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="SquareButton" TargetType="Button">
            <Border
                Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}"
                Margin="{TemplateBinding Margin}"
                Cursor="Hand">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </ControlTemplate>
        <Style x:Key="AcceptButton" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="PaleGreen"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Lime"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="PaleGreen"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RejectButton" TargetType="Button">
            <Setter Property="Background" Value="PaleVioletRed"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Red"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="PaleVioletRed"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image x:Name="CoverButton" Grid.Column="0" Source="{StaticResource GenericCover}" Cursor="Hand" MouseDown="CoverButton_MouseDown"/>
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label
                Grid.Row="0" Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}" FontSize="15">
                Name
            </Label>

            <TextBox x:Name="NameTextBox"
                Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}" FontSize="15" Background="#0AFFFFFF" BorderBrush="DarkGray"
                KeyDown="TextBox_KeyDown"
            />
            <Label
                Grid.Row="1" Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}" FontSize="15">
                Tag
            </Label>
            <TextBox x:Name="TagTextBox"
                Grid.Row="1" Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}" FontSize="15" Background="#0AFFFFFF" BorderBrush="DarkGray"
                KeyDown="TextBox_KeyDown"
            />
            <Button
                Grid.Row="1" Grid.Column="2"
                Style="{StaticResource AcceptButton}" Template="{StaticResource CircularButton}"
                Click="AddTag_Click"
                Width="27" Height="25" Margin="3 0 0 0">
                <icons:Material Kind="Plus" Width="15" Height="15"/>
            </Button>

            <ListBox x:Name="TagList"
                Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Foreground="{StaticResource FontColor}" FontSize="15" Background="#0AFFFFFF" BorderBrush="DarkGray"
                Margin="10 10 0 10"
                SelectionChanged="TagList_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft"
                Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                <Button
                    Style="{StaticResource AcceptButton}" Template="{StaticResource SquareButton}"
                    Padding="5" Margin="0 0 5 0"
                    Click="SaveButton_Click">
                    <icons:Material Kind="ContentSave"/>
                </Button>
                <Button x:Name="DeleteCollectionButton"
                        Style="{StaticResource RejectButton}" Template="{StaticResource SquareButton}"
                        Padding="5" Margin="5 0 0 0"
                        Click="Delete_Button">
                    <icons:Material Kind="TrashCan"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
